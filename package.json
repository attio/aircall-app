{
  "name": "aircall",
  "description": "Aircall",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "attio": "attio",
    "dev": "attio dev",
    "build": "attio build",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "clean": "rm -rf lib && rm -rf dist",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "knip": "knip"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.34.1",
    "@typescript-eslint/parser": "^8.34.1",
    "@types/node": "^24.0.4",
    "@types/react": "19.2.14",
    "eslint": "^9.29.0",
    "knip": "^6.14.0",
    "prettier": "^3.5.3",
    "typescript": "5.8.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@attio/fetchable": "^0.0.1-experimental.9",
    "attio": "0.0.1-experimental.20260715",
    "date-fns": "4.1.0",
    "react": "19.0.0",
    "zod": "3.25.67"
  },
  "packageManager": "pnpm@10.33.3",
  "pnpm": {
    "overrides": {
      "rollup": "4.34.9"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "keytar"
    ]
  }
}
